{
  "name": "@jellybrick/wql-process-monitor",
  "version": "3.0.0",
  "description": "Monitor Windows process creation/deletion events via WMI (WQL)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "os": [
    "win32"
  ],
  "cpu": [
    "x64",
    "ia32",
    "arm64"
  ],
  "engines": {
    "node": "^14.18.0 || >=16.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "build:all": "npm run build:native && npm run build",
    "build:native": "node ./rust/build.mjs x64 ia32 arm64",
    "build:native:x64": "node ./rust/build.mjs x64",
    "build:native:ia32": "node ./rust/build.mjs ia32",
    "build:native:arm64": "node ./rust/build.mjs arm64",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "pretty": "npx prettier --write ./**/*.{cjs,mjs,js,ts}"
  },
  "keywords": [
    "windows",
    "wmi",
    "wql",
    "process",
    "monitor",
    "InstanceOperationEvent",
    "InstanceCreationEvent",
    "InstanceDeletionEvent"
  ],
  "author": {
    "name": "Anthony Beaumont",
    "email": "dev.xan105@outlook.be",
    "url": "https://xan105.com/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JellyBrick/node-processMonitor.git"
  },
  "bugs": {
    "url": "https://github.com/JellyBrick/node-processMonitor/issues"
  },
  "homepage": "https://github.com/JellyBrick/node-processMonitor#readme",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "3.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  }
}
